{
  "name": "dark-web-alert-detection",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "@types/bun": "^1.3.4",
      "better-auth": "1.5.2",
      "lucide-react": "^0.546.0",
      "next-themes": "^0.4.6",
      "react": "^19.2.3",
      "react-dom": "^19.2.3",
      "sonner": "^2.0.5",
      "@prisma/client": "^7.2.0",
      "@types/react": "^19.2.10",
      "@types/react-dom": "^19.2.3",
      "tailwindcss": "^4.1.18"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "dev:crawler": "turbo -F crawler dev",
    "crawler:seed": "turbo -F crawler seed",
    "crawler:start": "turbo -F crawler start",
    "db:push": "turbo -F @dark-web-alert-detection/db db:push",
    "db:studio": "turbo -F @dark-web-alert-detection/db db:studio",
    "db:generate": "turbo -F @dark-web-alert-detection/db db:generate",
    "db:migrate": "turbo -F @dark-web-alert-detection/db db:migrate",
    "check": "biome check --write .",
    "prepare": "husky"
  },
  "dependencies": {
    "@dark-web-alert-detection/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.0",
    "@dark-web-alert-detection/config": "workspace:*",
    "@types/bun": "catalog:",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.2",
    "turbo": "^2.8.12",
    "typescript": "^5"
  },
  "lint-staged": {
    "*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": [
      "biome check --write ."
    ]
  },
  "packageManager": "bun@1.3.2"
}
