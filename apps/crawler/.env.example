# ─── Database ───────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# ─── Environment ────────────────────────────────────────
NODE_ENV="development"

# ─── Tor Proxy ──────────────────────────────────────────
# The socks5h:// scheme ensures DNS resolution happens on the Tor side,
# which is required for resolving .onion addresses.
TOR_PROXY_URL="socks5h://127.0.0.1:9050"

# ─── Crawler Settings ──────────────────────────────────
# Max number of concurrent page fetches
CRAWLER_CONCURRENCY=3

# Delay between crawl cycles in milliseconds (default: 30s)
CRAWLER_INTERVAL_MS=30000

# HTTP request timeout in milliseconds (default: 30s)
CRAWLER_REQUEST_TIMEOUT_MS=30000

# Max retries per URL before giving up
CRAWLER_MAX_RETRIES=3

# Max link-follow depth from a seed URL (0 = seed only, no link following)
CRAWLER_MAX_DEPTH=3

# ─── Logging ────────────────────────────────────────────
# Log level: debug | info | warn | error
LOG_LEVEL="debug"

# ─── Seeding ────────────────────────────────────────────
# Set to "true" to include placeholder .onion sources when running `bun run seed`
SEED_ONION="false"
